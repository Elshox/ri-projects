# ──────────────────────────────────────────────────────────
# RI PROJECTS — Environment Variables
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://riprojects.org

# ── Telegram Lead Notifications ──────────────────────────
# 1. Create a bot via @BotFather → get token
# 2. Add bot to a group → send a message → call
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find chat_id
TELEGRAM_BOT_TOKEN=123456789:AAF_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890

# ── Resend Email ─────────────────────────────────────────
# Get API key at https://resend.com/api-keys
# Verify sending domain before going live.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@riprojects.org
RESEND_TO_EMAIL=sales@riprojects.org

# ── Analytics ────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_YANDEX_ID=12345678

# ── Search Console Verification ──────────────────────────
NEXT_PUBLIC_GOOGLE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_YANDEX_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
