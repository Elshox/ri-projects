# pnpm: класть зависимости плоско, как у npm. Без этого Next.js
# не находит свои внутренние пути на Netlify (ошибка "Couldn't
# find any pages or app directory") — pnpm по умолчанию делает
# symlink-based hoisting, что ломает поиск роутов.
shamefully-hoist=true
node-linker=hoisted

# auto-install peer deps (next-intl, motion и пр.)
auto-install-peers=true

# CI: пропускаем интерактивные вопросы
loglevel=warn
